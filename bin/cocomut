#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PROJECT_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
JAR="$PROJECT_ROOT/dist/cocomut-cli.jar"
DEV_JAR="$PROJECT_ROOT/cocomut-cli/target/cocomut-cli-0.1.0-all.jar"

if [ -f "$JAR" ]; then
  exec java -jar "$JAR" "$@"
fi

if [ ! -f "$DEV_JAR" ]; then
  mvn -q -f "$PROJECT_ROOT/pom.xml" -pl cocomut-cli -am -DskipTests package
fi

exec java -jar "$DEV_JAR" "$@"
