{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assert-lab.github.io/cocomut/schemas/method-context.schema.json",
  "title": "CoCoMUT Method Context",
  "type": "object",
  "required": ["MUT", "metadata", "provenance", "documentation_metrics", "javadoc_metadata", "dynamic_features"],
  "properties": {
    "MUT": {
      "type": "object",
      "required": [
        "method_uri",
        "method_name",
        "source_set",
        "signature",
        "return_type",
        "erased_return_type",
        "qualified_name",
        "parameters",
        "code",
        "javadoc",
        "class_hierarchy",
        "source_context"
      ],
      "properties": {
        "method_uri": {
          "type": "string",
          "description": "Canonical CoCoMUT method URI: relative/path.java#qualified.Class.method(erasedParamTypes):erasedReturnType"
        },
        "method_name": {"type": "string"},
        "source_set": {"type": "string"},
        "signature": {"type": "string"},
        "return_type": {"type": "string"},
        "erased_return_type": {"type": "string"},
        "qualified_name": {"type": "string"},
        "line_number": {"type": "integer"},
        "parameters": {"type": "array"},
        "annotations": {"type": "array"},
        "throws": {"type": "array"},
        "lines_of_code": {
          "type": "integer",
          "description": "Lexical estimate derived from emitted method source; not an AST structural metric."
        },
        "cyclomatic_complexity": {
          "type": "integer",
          "description": "Lexical branch-token estimate derived from emitted method source; not an AST/control-flow McCabe metric."
        },
        "code": {
          "type": "string",
          "description": "Method or constructor source without leading Javadoc. Method annotations are kept."
        },
        "javadoc": {
          "type": "string",
          "description": "Method Javadoc stored separately from method source."
        },
        "class_hierarchy": {"type": "object"},
        "source_context": {"type": "object"},
        "class_javadoc": {"type": "string"}
      },
      "additionalProperties": true
    },
    "callers": {
      "type": "array",
      "items": {"$ref": "#/$defs/callGraphEdge"}
    },
    "callees": {
      "type": "array",
      "items": {"$ref": "#/$defs/callGraphEdge"}
    },
    "metadata": {
      "type": "object",
      "required": [
        "schema_version",
        "source_backend",
        "source_backend_mode",
        "method_identity",
        "type_resolution",
        "call_graph"
      ],
      "properties": {
        "schema_version": {"type": "string"},
        "source_backend": {"type": "string"},
        "source_backend_mode": {"type": "string"},
        "method_identity": {"type": "string"},
        "type_resolution": {"type": "string"},
        "call_graph": {"type": "object"}
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "properties": {
        "method_source": {"type": "string"},
        "method_matching": {"type": "string"},
        "javadoc_extraction": {"type": "string"},
        "compiled_project": {"type": "boolean"},
        "context_confidence": {"type": "object"}
      },
      "additionalProperties": true
    },
    "documentation_metrics": {
      "type": "object",
      "properties": {
        "parser": {
          "type": "string",
          "description": "Parser path used for documentation metrics, normally spoon-javadoc."
        },
        "parse_confidence": {
          "type": "string",
          "description": "high for spoon-javadoc parsed metrics, low for fallback text parsing."
        }
      },
      "additionalProperties": true
    },
    "javadoc_metadata": {
      "type": "object",
      "properties": {
        "see": {"type": "array"},
        "inline_links": {"type": "array"},
        "javadoc_references": {
          "type": "array",
          "items": {"$ref": "#/$defs/javadocReference"}
        },
        "file_references": {
          "type": "array",
          "description": "Auxiliary documentation file/path references. Entries include parser, parse_confidence, source_form, containment-checked resolved_path, and exists."
        },
        "structured_tags": {
          "type": "object",
          "description": "Parser-derived param/return/throws/since/apiNote/implSpec/implNote/deprecated tags. Includes parser and parse_confidence."
        },
        "uses_inheritdoc": {"type": "boolean"},
        "inheritdoc_policy": {
          "type": "string",
          "description": "not_applicable when inheritDoc is absent; candidate_only when inherited documentation candidates are reported without silently expanding child structured tags."
        },
        "inheritdoc_resolution": {"type": "string"},
        "inherited_javadoc_candidates": {"type": "array"}
      },
      "additionalProperties": true
    },
    "dynamic_features": {"type": "array"},
    "selection": {
      "type": "object",
      "properties": {
        "kind": {"type": "string"},
        "uri": {"type": "string"},
        "selector": {"type": "string"},
        "targets": {"type": "array"}
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "callGraphEdge": {
      "type": "object",
      "required": [
        "kind",
        "method_uri",
        "target_uri",
        "target_kind",
        "raw_signature",
        "declaring_class",
        "method_name",
        "resolution"
      ],
      "properties": {
        "kind": {"type": "string"},
        "method_uri": {"type": "string"},
        "target_uri": {
          "type": "string",
          "description": "Universal bytecode-level target URI derived from the SootUp signature."
        },
        "target_kind": {
          "type": "string",
          "description": "project_method|unresolved_project_method|jdk_method|external_method|bytecode_method|invokedynamic_method|synthetic_or_compiler_method"
        },
        "raw_signature": {"type": "string"},
        "declaring_class": {"type": "string"},
        "method_name": {"type": "string"},
        "resolution": {"type": "string"},
        "context_in_output": {
          "type": "boolean",
          "description": "True when the resolved project method's full context is included in the current JSONL output selection."
        },
        "candidate_method_uris": {"type": "array", "items": {"type": "string"}},
        "unresolved_reason": {
          "type": "string",
          "description": "Deterministic reason why method_uri is empty, for example project_class_present_method_absent_record_component_accessor or jdk_or_platform_method_outside_project_source."
        },
        "context": {"type": "object"}
      },
      "additionalProperties": true
    },
    "javadocReference": {
      "type": "object",
      "required": ["tag", "raw", "target", "kind", "resolution"],
      "properties": {
        "tag": {"type": "string"},
        "raw": {"type": "string"},
        "target": {"type": "string"},
        "canonical_target": {
          "type": "string",
          "description": "Parser-normalized target when it differs from the source Javadoc spelling preserved in target."
        },
        "label": {"type": "string"},
        "text": {"type": "string"},
        "parser": {
          "type": "string",
          "description": "Parser path used for the reference, for example spoon-javadoc or cocomut-fallback."
        },
        "parse_confidence": {
          "type": "string",
          "description": "high for typed spoon-javadoc references, medium for Spoon text fallback, low for CoCoMUT fallback text parsing."
        },
        "spoon_reference": {
          "type": "string",
          "description": "Spoon-javadoc typed reference rendering when available."
        },
        "raw_pairing_confidence": {
          "type": "string",
          "description": "Confidence for pairing legacy raw target spelling with Spoon's typed reference; low/none pairings do not drive semantic resolution."
        },
        "fallback_reason": {
          "type": "string",
          "description": "Reason a low-confidence fallback reference was emitted, for example spoon_no_references or not_represented_by_spoon."
        },
        "kind": {"type": "string"},
        "resolution": {"type": "string"},
        "reference_target_kind": {"type": "string"},
        "reference_domain": {"type": "string"},
        "reference_scope": {"type": "string"},
        "method_uri": {"type": "string"},
        "field_uri": {"type": "string"},
        "type_uri": {"type": "string"},
        "referenced_method": {"type": "object"},
        "field_javadoc": {"type": "string"},
        "class_javadoc": {"type": "string"},
        "resolved_class": {"type": "string"},
        "referenced_member": {"type": "string"},
        "candidate_method_uris": {"type": "array"},
        "candidate_field_uris": {"type": "array"},
        "ambiguity_reason": {"type": "string"},
        "external_class": {"type": "string"},
        "external_member": {"type": "string"},
        "external_resolution": {"type": "string"},
        "external_member_kind": {"type": "string"},
        "external_member_resolution": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
